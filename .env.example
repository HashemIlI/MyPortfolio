# Database
# Required in production.
# Prefer a non-SRV Atlas seed-list URI if local DNS has trouble with mongodb+srv.
# On Vercel, set the same variable in Project Settings -> Environment Variables.
MONGODB_URI=mongodb://<username>:<password>@<host-1>:27017,<host-2>:27017,<host-3>:27017/portfolio?ssl=true&replicaSet=<replica-set-name>&authSource=admin&retryWrites=true&w=majority&appName=portfolio-cms
# Atlas SRV alternative:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/portfolio?retryWrites=true&w=majority&appName=portfolio-cms
# Local fallback:
# MONGODB_URI=mongodb://127.0.0.1:27017/portfolio

# Auth
# Required in production.
# Generate with: openssl rand -base64 32
JWT_SECRET=<replace-with-a-long-random-secret>
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<replace-with-a-strong-password>

# GitHub Integration (optional)
GITHUB_TOKEN=
GITHUB_USERNAME=

# Public App URL
# Required for canonical production URL.
# Local example: http://localhost:3000
# Vercel example: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Deployment note:
# On Vercel, local filesystem uploads under /public/uploads are not writable at runtime.
# If you need admin media uploads in production, use external object storage or deploy on a server with persistent disk.
